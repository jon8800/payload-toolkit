{
  "name": "payload-starter",
  "version": "1.0.0",
  "description": "Composable block-based Payload CMS website starter",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "setup": "tsx scripts/setup.ts",
    "seed:demo": "cross-env NODE_OPTIONS=--no-deprecation payload run ./scripts/seed-demo.ts",
    "create:admin": "cross-env NODE_OPTIONS=--no-deprecation payload run ./scripts/create-admin.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@payloadcms/db-postgres": "^3.79.0",
    "@payloadcms/live-preview-react": "^3.79.0",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/plugin-form-builder": "^3.79.0",
    "@payloadcms/plugin-import-export": "^3.79.0",
    "@payloadcms/plugin-mcp": "^3.79.0",
    "@payloadcms/plugin-nested-docs": "^3.79.0",
    "@payloadcms/plugin-redirects": "^3.79.0",
    "@payloadcms/plugin-search": "^3.79.0",
    "@payloadcms/plugin-seo": "^3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/translations": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.0",
    "google-font-metadata": "^6.0.8",
    "graphql": "^16.8.2",
    "input-otp": "^1.4.2",
    "lucide-react": "0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.2",
    "payload": "^3.79.0",
    "react": "19.2.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.1",
    "react-resizable-panels": "^4.7.2",
    "recharts": "2.15.4",
    "shadcn": "^4.0.6",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/culori": "^4.0.1",
    "@types/node": "22.19.9",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "pg": "^8.20.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
