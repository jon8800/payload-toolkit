              label: 'Customiser',
            },
          },
        },
      },
    },
  },
  versions: {
    maxPerDoc: 50,
    drafts: {
      autosave: { interval: 300 },
    },
  },
  trash: true,
  enableQueryPresets: true,
  hooks: {
    afterChange: [revalidateTemplatePart],
  },
  fields: [
    {
      name: 'title',
      type: 'text',
      required: true,
